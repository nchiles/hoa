# Supabase
# In Vercel, set the prod values from Project Settings → API.
# Locally, copy the publishable key from the dashboard or `npx supabase start` output.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-role key — server-only. NEVER expose to the browser.
# Used by src/lib/supabase/admin.ts for board invite flow.
SUPABASE_SERVICE_ROLE_KEY=
